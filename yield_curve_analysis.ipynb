      "cell_type": "markdown",
      "source": [
        "Download Data"
      ],
      "metadata": {
        "id": "0PkLzbKqyXGf"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from fredapi import Fred\n",
        "\n",
        "fred = Fred(api_key=\"fea2436504ac76c0624153b11fed8c4c\")\n",
        "\n",
        "y2 = fred.get_series('DGS2')\n",
        "y10 = fred.get_series('DGS10')\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    \"2Y\": y2,\n",
        "    \"10Y\": y10\n",
        "}).dropna()\n",
        "\n",
        "df[\"Spread\"] = df[\"10Y\"] - df[\"2Y\"]\n",
        "\n",
        "plt.figure(figsize=(10,6))\n",
        "plt.plot(df.index, df[\"10Y\"], label=\"10Y Yield\")\n",
        "plt.plot(df.index, df[\"2Y\"], label=\"2Y Yield\")\n",
        "\n",
        "plt.title(\"Treasury Yield Curve Dynamics\")\n",
        "plt.xlabel(\"Date\")\n",
        "plt.ylabel(\"Yield (%)\")\n",
        "plt.legend()\n",
        "plt.grid()\n",
        "\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
